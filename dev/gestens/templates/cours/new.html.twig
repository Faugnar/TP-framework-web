{% extends 'base.html.twig' %}

{% block title %}Créer un cours{% endblock %}

{% block body %}
    <h1 class="mb-4">Créer un nouveau cours</h1>

    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_widget(form) }}
                <div class="mt-3">
                    <button type="submit" class="btn btn-success">Créer</button>
                    <a href="{{ path('app_cours_index') }}" class="btn btn-secondary">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}