{% extends 'base.html.twig' %}

{% block title %}{{ cours.nom }}{% endblock %}

{% block body %}
    <h1 class="mb-4">{{ cours.nom }}</h1>

    <div class="card">
        <div class="card-body">
            <table class="table table-borderless">
                <tr>
                    <th style="width: 200px;">Semestre</th>
                    <td>{{ cours.semestre }}</td>
                </tr>
                <tr>
                    <th>Nom</th>
                    <td>{{ cours.nom }}</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ cours.description }}</td>
                </tr>
            </table>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <a href="{{ path('app_cours_edit', {'id': cours.id}) }}" class="btn btn-primary">
            Modifier
        </a>
        
        {{ include('cours/_delete_form.html.twig') }}
        
        <a href="{{ path('app_cours_index') }}" class="btn btn-secondary">
            Retour à la liste
        </a>
    </div>
{% endblock %}