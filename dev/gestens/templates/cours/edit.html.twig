{% extends 'base.html.twig' %}

{% block title %}Modifier {{ cours.nom }}{% endblock %}

{% block body %}
    <h1 class="mb-4">Modifier : {{ cours.nom }}</h1>

    <div class="card">
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_widget(form) }}
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">Mettre à jour</button>
                    <a href="{{ path('app_cours_show', {'id': cours.id}) }}" class="btn btn-secondary">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}