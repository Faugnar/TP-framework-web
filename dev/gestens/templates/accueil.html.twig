{% extends 'base.html.twig' %}

{% block title %}Accueil - Gestion des cours{% endblock %}

{% block body %}
    <div class="jumbotron">
        <h1 class="display-4">Bienvenue dans l'application de gestion des cours</h1>
        <p class="lead">Utilisez le menu de navigation pour accéder aux différentes fonctionnalités.</p>
        <hr class="my-4">
    </div>
    
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Consulter les cours</h5>
                    <p class="card-text">Parcourez la liste complète des cours disponibles.</p>
                    <a href="{{ path('app_cours_index') }}" class="btn btn-primary">Voir les cours</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Créer un cours</h5>
                    <p class="card-text">Ajoutez un nouveau cours à la base de données.</p>
                    <a href="{{ path('app_cours_new') }}" class="btn btn-success">Créer un cours</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}